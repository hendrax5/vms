generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id              Int              @id @default(autoincrement())
  key             String           @unique
  label           String
  group           String           @default("other")
  rolePermissions RolePermission[]
  userPermissions UserPermission[]
}

model RolePermission {
  roleId       Int
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserPermission {
  userId       Int
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

model User {
  id                     Int                      @id @default(autoincrement())
  email                  String                   @unique
  name                   String?
  password               String                   @default("password123")
  roleId                 Int
  datacenterId           Int?
  customerId             Int?
  apiLogs                ApiLog[]
  InfrastructureAuditLog InfrastructureAuditLog[]
  assignedTickets        SupportTicket[]          @relation("AssignedTickets")
  reportedTickets        SupportTicket[]          @relation("ReportedTickets")
  systemAuditLogs        SystemAuditLog[]
  ticketComments         TicketComment[]
  customer               Customer?                @relation(fields: [customerId], references: [id])
  datacenter             Datacenter?              @relation(fields: [datacenterId], references: [id])
  role                   Role                     @relation(fields: [roleId], references: [id])
  permissions            UserPermission[]
  permitsApproved        VisitPermit[]            @relation("PermitApprover")
}

model Region {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  code        String       @unique
  datacenters Datacenter[]
}

model Datacenter {
  id                       Int                       @id @default(autoincrement())
  regionId                 Int
  code                     String                    @unique
  name                     String
  nocEmail                 String?
  createdAt                DateTime                  @default(now())
  crossConnects            CrossConnect[]
  rooms                    DataRoom[]
  region                   Region                    @relation(fields: [regionId], references: [id])
  mailConfig               DatacenterMailConfig?
  goods                    GoodsItem[]
  inboxMessages            InboxMessage[]
  interconnectionProviders InterconnectionProvider[]
  supportTickets           SupportTicket[]
  users                    User[]
  permits                  VisitPermit[]
}

model DataRoom {
  id           Int        @id @default(autoincrement())
  datacenterId Int
  name         String
  datacenter   Datacenter @relation(fields: [datacenterId], references: [id], onDelete: Cascade)
  rows         Row[]
}

model Row {
  id     Int      @id @default(autoincrement())
  roomId Int
  name   String
  racks  Rack[]
  room   DataRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model Rack {
  id         Int                 @id @default(autoincrement())
  rowId      Int
  customerId Int?
  name       String
  uCapacity  Int                 @default(42)
  createdAt  DateTime            @default(now())
  customer   Customer?           @relation(fields: [customerId], references: [id])
  row        Row                 @relation(fields: [rowId], references: [id], onDelete: Cascade)
  equipments RackEquipment[]
  affectedBy VendorMaintenance[] @relation("MaintenanceAffectedRacks")
}

model Customer {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  code           String?         @unique
  contactEmail   String?
  contactPhone   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  crossConnects  CrossConnect[]
  goods          GoodsItem[]
  racks          Rack[]
  rackEquipments RackEquipment[]
  supportTickets SupportTicket[]
  users          User[]
  permits        VisitPermit[]
}

model RackEquipment {
  id                     Int                      @id @default(autoincrement())
  rackId                 Int
  customerId             Int?
  name                   String
  equipmentType          String
  uStart                 Int
  uEnd                   Int
  orientation            String                   @default("FRONT")
  status                 String                   @default("Active")
  createdAt              DateTime                 @default(now())
  arrivalDate            DateTime?
  serialNumber           String?
  weight                 String?
  ports                  EquipmentPort[]
  InfrastructureAuditLog InfrastructureAuditLog[]
  customer               Customer?                @relation(fields: [customerId], references: [id])
  rack                   Rack                     @relation(fields: [rackId], references: [id], onDelete: Cascade)
}

model InfrastructureAuditLog {
  id            Int           @id @default(autoincrement())
  equipmentId   Int
  userId        Int?
  action        String
  previousState String?
  newState      String?
  timestamp     DateTime      @default(now())
  equipment     RackEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [userId], references: [id])
}

model EquipmentPort {
  id            Int            @id @default(autoincrement())
  equipmentId   Int
  portName      String
  crossConnectA CrossConnect[] @relation("CrossConnectSideAPort")
  crossConnectZ CrossConnect[] @relation("CrossConnectSideZPort")
  crossConnectMmrA CrossConnect[] @relation("CrossConnectMmrSideAPort")
  crossConnectMmrZ CrossConnect[] @relation("CrossConnectMmrSideZPort")
  equipment     RackEquipment  @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
}

model GoodsItem {
  id           Int        @id @default(autoincrement())
  qrCode       String     @unique
  datacenterId Int
  customerId   Int?
  name         String
  description  String?
  status       String
  scannedAt    DateTime?
  createdAt    DateTime   @default(now())
  arrivalDate  DateTime?
  serialNumber String?
  weight       String?
  customer     Customer?  @relation(fields: [customerId], references: [id])
  datacenter   Datacenter @relation(fields: [datacenterId], references: [id])
}

model VisitPermit {
  id             Int              @id @default(autoincrement())
  datacenterId   Int
  customerId     Int?
  companyName    String?
  visitorNames   String
  visitorPhoto   String?
  activity       String
  scheduledAt    DateTime
  checkInAt      DateTime?
  checkOutAt     DateTime?
  status         String           @default("Pending")
  approvedById   Int?
  ndaSignedAt    DateTime?
  qrCodeToken    String?          @unique
  requiresEscort Boolean          @default(false)
  zoneAccess     String[]
  createdAt      DateTime         @default(now())
  accessCard     AccessCard?
  eventLogs      PermitEventLog[]
  approvedBy     User?            @relation("PermitApprover", fields: [approvedById], references: [id])
  customer       Customer?        @relation(fields: [customerId], references: [id])
  datacenter     Datacenter       @relation(fields: [datacenterId], references: [id])
}

model PermitEventLog {
  id        Int         @id @default(autoincrement())
  permitId  Int
  status    String
  message   String?
  timestamp DateTime    @default(now())
  permit    VisitPermit @relation(fields: [permitId], references: [id], onDelete: Cascade)
}

model CrossConnect {
  id             Int            @id @default(autoincrement())
  datacenterId   Int
  customerId     Int?
  mediaType      String         @default("Singlemode Fiber")
  sideAPortId    Int
  sideZPortId    Int?
  targetType     String?
  targetProvider String?
  status         String         @default("Requested")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  apjiiCode      String?
  ewoCode        String?
  labelNumber    String?
  notes          String?
  sideACompany   String?
  sideZCompany   String?
  customer       Customer?      @relation(fields: [customerId], references: [id])
  datacenter     Datacenter     @relation(fields: [datacenterId], references: [id])
  sideAPort      EquipmentPort  @relation("CrossConnectSideAPort", fields: [sideAPortId], references: [id], onDelete: Cascade)
  sideZPort      EquipmentPort? @relation("CrossConnectSideZPort", fields: [sideZPortId], references: [id], onDelete: Cascade)
  mmrSideAPortId Int?
  mmrSideZPortId Int?
  mmrSideAPort   EquipmentPort? @relation("CrossConnectMmrSideAPort", fields: [mmrSideAPortId], references: [id], onDelete: SetNull)
  mmrSideZPort   EquipmentPort? @relation("CrossConnectMmrSideZPort", fields: [mmrSideZPortId], references: [id], onDelete: SetNull)
}

model InterconnectionProvider {
  id           Int         @id @default(autoincrement())
  name         String
  type         String
  datacenterId Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  datacenter   Datacenter? @relation(fields: [datacenterId], references: [id], onDelete: Cascade)
}

model VendorMaintenance {
  id              Int       @id @default(autoincrement())
  type            String
  startTime       DateTime
  endTime         DateTime?
  slaDowntimeMins Int       @default(0)
  description     String?
  createdAt       DateTime  @default(now())
  affectedRacks   Rack[]    @relation("MaintenanceAffectedRacks")
}

model AccessCard {
  id              Int          @id @default(autoincrement())
  cardNumber      String       @unique
  status          String       @default("Available")
  currentPermitId Int?         @unique
  updatedAt       DateTime     @updatedAt
  currentPermit   VisitPermit? @relation(fields: [currentPermitId], references: [id])
}

model ApiLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  endpoint  String
  method    String
  action    String
  status    Int
  timestamp DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model SystemAuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  resource  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model SupportTicket {
  id              Int             @id @default(autoincrement())
  customerId      Int?
  reporterId      Int
  assigneeId      Int?
  datacenterId    Int?
  subject         String
  description     String
  priority        String          @default("Medium")
  status          String          @default("Open")
  category        String          @default("General")
  slaDowntimeMins Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  resolvedAt      DateTime?
  assignee        User?           @relation("AssignedTickets", fields: [assigneeId], references: [id])
  customer        Customer?       @relation(fields: [customerId], references: [id])
  datacenter      Datacenter?     @relation(fields: [datacenterId], references: [id])
  reporter        User            @relation("ReportedTickets", fields: [reporterId], references: [id])
  comments        TicketComment[]
}

model TicketComment {
  id         Int           @id @default(autoincrement())
  ticketId   Int
  authorId   Int
  body       String
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())
  author     User          @relation(fields: [authorId], references: [id])
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model DatacenterMailConfig {
  id           Int        @id @default(autoincrement())
  datacenterId Int        @unique
  imapHost     String
  imapPort     Int        @default(993)
  imapUser     String
  imapPass     String
  smtpHost     String
  smtpPort     Int        @default(465)
  smtpUser     String
  smtpPass     String
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  datacenter   Datacenter @relation(fields: [datacenterId], references: [id], onDelete: Cascade)
}

model InboxMessage {
  id           Int        @id @default(autoincrement())
  datacenterId Int
  messageId    String     @unique
  threadId     String?
  from         String
  to           String
  subject      String
  bodyText     String
  htmlContent  String?
  isRead       Boolean    @default(false)
  receivedAt   DateTime   @default(now())
  repliedAt    DateTime?
  datacenter   Datacenter @relation(fields: [datacenterId], references: [id], onDelete: Cascade)
}
